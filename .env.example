# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=aicontrol
POSTGRES_PASSWORD=change_me
POSTGRES_DB=aicontrol
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── SQLAlchemy (derived from above) ──────────────────────────────────────────
# In Docker: hostname is '"postgres"' (the service name)
# In local dev: use '"localhost"' instead
DATABASE_URL=postgresql+asyncpg://aicontrol:change_me@postgres:5432/aicontrol

# ── OPA ───────────────────────────────────────────────────────────────────────
OPA_URL=http://opa:8181

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production

# Intentionally empty for Docker — the API does not require a signing secret
# when deployed via install.sh. Set a value only for local dev outside Docker.
SECRET_KEY=

# ── Admin access ──────────────────────────────────────────────────────────────
# Generated by install.sh. To regenerate:
#   docker compose -f docker-compose.yml -f docker-compose.app.yml #     exec api python scripts/issue_token.py --role admin --desc "admin"
ADMIN_TOKEN=

# ── Dashboard → API connection ────────────────────────────────────────────────
# The URL the dashboard container uses to reach the API.
# In Docker Compose: use the service name '"api"', not '"localhost"'
AICONTROL_API_URL=http://api:8001

# ── Slack HITL (optional — press Enter to skip during install) ───────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_REVIEW_CHANNEL=#aicontrol-reviews

# Enterprise license (empty = community edition)
AICONTROL_LICENSE_KEY=

# AI-native features — customer provides own API key
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
LLM_API_KEY=
LLM_MOCK_ENABLED=false
LLM_MAX_LATENCY_MS=3000

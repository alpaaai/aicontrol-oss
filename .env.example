# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=aicontrol
POSTGRES_PASSWORD=change_me
POSTGRES_DB=aicontrol
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── SQLAlchemy (derived from above) ───────────────────────────────────────────
# In Docker: hostname is 'postgres' (the service name)
# In local dev: change 'postgres' to 'localhost'
DATABASE_URL=postgresql+asyncpg://aicontrol:change_me@postgres:5432/aicontrol

# ── OPA ────────────────────────────────────────────────────────────────────────
OPA_URL=http://opa:8181

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production

# JWT signing secret. Auto-generated by install.sh. Set for local dev.
SECRET_KEY=

# ── Admin access ───────────────────────────────────────────────────────────────
# Written by install.sh after first startup. To regenerate:
#   docker compose -f docker-compose.yml -f docker-compose.app.yml \
#     exec api python scripts/issue_token.py --role admin --desc "admin"
ADMIN_TOKEN=

# ── Slack HITL (optional) ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_REVIEW_CHANNEL=#aicontrol-reviews

# ── React Dashboard ───────────────────────────────────────────────────────────
# [community] URL the browser uses to reach the API.
# In Docker Compose: localhost:8001. On remote server: your server's IP/hostname.
# Baked into the frontend image at build time. Rebuild required after change:
#   docker compose build frontend
VITE_API_URL=http://localhost:8001

# [enterprise] Set to "true" to unlock enterprise dashboard sections.
# Requires AICONTROL_LICENSE_KEY to also be set.
VITE_ENTERPRISE=false

# ── OPA Health-Watch ──────────────────────────────────────────────────────────
# [community] Behavior when OPA is unreachable during policy evaluation.
# "deny" = fail-closed (safest, default). "allow" = fail-open (not recommended).
OPA_FAILURE_MODE=deny

# [community] How often the OPA health watcher polls OPA. Seconds.
OPA_POLL_INTERVAL_SECONDS=30

# ── Policy Drift Detection ────────────────────────────────────────────────────
# [enterprise] How often to scan for stale or ungoverned policies. Hours.
DRIFT_SCAN_INTERVAL_HOURS=6

# ── Enterprise License ────────────────────────────────────────────────────────
# Empty = community edition (Apache 2.0, free).
# Set to your license key to unlock:
#   - OPA health-watch observability (Health page)
#   - Policy drift detection + warning feed (Governance → Warnings)
#   - Compliance report export — SOC 2, PCI, HIPAA, GLBA (Reports page)
# Contact: enterprise@aictl.io
AICONTROL_LICENSE_KEY=

# ── AI-Native Features ────────────────────────────────────────────────────────
# [enterprise] Customer provides their own LLM API key.
# Used for: compliance report generation (P1-7).
# AIControl never stores or transmits your key outside your environment.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
LLM_API_KEY=
# Set true to use mock responses (no API key needed — for trial and CI).
LLM_MOCK_ENABLED=false
LLM_MAX_LATENCY_MS=3000
